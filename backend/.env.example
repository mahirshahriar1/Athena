# =============================================================================
# Athena Backend — Environment Variables
# =============================================================================
# Copy this to .env: cp .env.example .env

# --- LLM Provider ---
# Options: "groq" (free) or "anthropic" (paid)
LLM_PROVIDER=groq

# Groq (FREE — sign up at https://console.groq.com)
GROQ_API_KEY=gsk_your-groq-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic (PAID — only needed if LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Embedding Provider ---
# Options: "huggingface" (free, runs locally) or "openai" (paid)
EMBEDDING_PROVIDER=huggingface

# HuggingFace (FREE — downloads model on first run, no API key)
# Recommended models:
#   BAAI/bge-small-en-v1.5  — best quality/speed (default, 130MB)
#   all-mpnet-base-v2       — highest quality (420MB, slower)
#   all-MiniLM-L6-v2        — fastest (90MB, slightly lower quality)
HF_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# OpenAI (PAID — only needed if EMBEDDING_PROVIDER=openai)
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./data/chroma

# --- Server ---
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000

# --- Rate Limiting ---
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW=3600
